<% layout("layouts/boilerplate") %>

<div class="container mt-5">
  <div class="row justify-content-center">

    <div class="col-md-5">

      <div class="card shadow border-0 rounded-4">

        <div class="card-body p-4">

          <div class="text-center mb-4">

            <% if(portal === "user") { %>
              <i class="fa-solid fa-user fs-1 text-primary"></i>
            <% } else if(portal === "host") { %>
              <i class="fa-solid fa-house-user fs-1 text-danger"></i>
            <% } else { %>
              <i class="fa-solid fa-shield-halved fs-1 text-success"></i>
            <% } %>

            <h2 class="mt-3 fw-bold">
              <%= title %>
            </h2>

          </div>

          <form action="<%= action %>" method="POST">

            <div class="mb-3">
              <label class="form-label">
                Username
              </label>

              <input
                type="text"
                name="username"
                class="form-control"
                required
              >
            </div>

            <div class="mb-4">
              <label class="form-label">
                Password
              </label>

              <input
                type="password"
                name="password"
                class="form-control"
                required
              >
            </div>

            <% if(portal === "user") { %>

              <button class="btn btn-primary w-100">
                Login
              </button>

            <% } else if(portal === "host") { %>

              <button class="btn btn-danger w-100">
                Host Login
              </button>

            <% } else { %>

              <button class="btn btn-success w-100">
                Admin Login
              </button>

            <% } %>

          </form>

          <% if(portal === "user") { %>

            <div class="text-center mt-4">

              <a href="/host/login" class="text-decoration-none">
                Become Host? Host Login
              </a>

              <br><br>

              <a href="/admin/login" class="text-decoration-none text-danger">
                Admin Login
              </a>

            </div>

          <% } %>

        </div>

      </div>

    </div>

  </div>
</div>