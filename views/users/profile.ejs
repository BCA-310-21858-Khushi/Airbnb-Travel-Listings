<% layout("layouts/boilerplate") %>

<div class="container mt-4">

  <div class="card border-0 shadow rounded-4">
    <div class="card-body p-5">

      <div class="text-center">
        <img
          src="<%= user.profileImage && user.profileImage.url ? user.profileImage.url : 'https://res.cloudinary.com/demo/image/upload/v1312461204/sample.jpg' %>"
          class="rounded-circle shadow mb-3"
          style="width:150px;height:150px;object-fit:cover;"
        >

        <h3 class="fw-bold"><%= user.username %></h3>
        <p class="text-muted"><%= user.email %></p>

        <% if(user.role === "user") { %>
          <form
            action="/become-host"
            method="POST"
            onsubmit="return confirm('Do you want to become a host?')"
            class="mb-3"
          >
            <button class="btn btn-danger">
              <i class="fa-solid fa-house-user"></i>
              Become a Host
            </button>
          </form>
        <% } else if(user.role === "host") { %>
          <div class="alert alert-success rounded-4">
            <i class="fa-solid fa-circle-check"></i>
            You are a verified Host.
          </div>
        <% } else if(user.role === "admin") { %>
          <div class="alert alert-danger rounded-4">
            <i class="fa-solid fa-shield-halved"></i>
            Admin Account
          </div>
        <% } %>

        <form
          action="/profile/photo"
          method="POST"
          enctype="multipart/form-data"
          class="mt-3"
        >
          <input
            type="file"
            name="profileImage"
            class="form-control mb-3"
            accept="image/*"
            required
          >

          <button class="btn btn-outline-danger">
            <i class="fa-solid fa-camera"></i>
            Update Profile Photo
          </button>
        </form>
      </div>

      <hr class="my-4">

      <div class="row text-center">
        <div class="col-md-4 mb-3">
          <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
              <h2 class="text-danger"><%= listingsCount %></h2>
              <p class="mb-0">My Listings</p>
            </div>
          </div>
        </div>

        <div class="col-md-4 mb-3">
          <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
              <h2 class="text-success"><%= bookingsCount %></h2>
              <p class="mb-0">My Bookings</p>
            </div>
          </div>
        </div>

        <div class="col-md-4 mb-3">
          <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
              <h2 class="text-primary"><%= wishlistCount %></h2>
              <p class="mb-0">Wishlist</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-4">
        <a href="/my-listings" class="btn btn-outline-danger">My Listings</a>
        <a href="/bookings/my-bookings" class="btn btn-outline-success">My Bookings</a>
        <a href="/wishlist" class="btn btn-outline-dark">Wishlist</a>
      </div>

    </div>
  </div>

</div>