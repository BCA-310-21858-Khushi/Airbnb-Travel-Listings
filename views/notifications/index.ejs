<% layout("layouts/boilerplate") %>

<%
  function timeAgo(date) {
    const seconds = Math.floor((new Date() - new Date(date)) / 1000);

    if (seconds < 60) return "Just now";

    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return minutes + " min ago";

    const hours = Math.floor(minutes / 60);
    if (hours < 24) return hours + " hour ago";

    const days = Math.floor(hours / 24);
    if (days === 1) return "Yesterday";

    return days + " days ago";
  }

  function notificationIcon(type) {
    if (type === "booking") return "fa-calendar-check text-success";
    if (type === "payment") return "fa-credit-card text-primary";
    if (type === "review") return "fa-star text-warning";
    if (type === "reply") return "fa-reply text-info";
    if (type === "cancel") return "fa-ban text-danger";
    return "fa-bell text-danger";
  }
%>

<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">
      <i class="fa-solid fa-bell text-danger"></i>
      Notifications
    </h2>

    <% if(notifications.length > 0) { %>
      <form
        action="/notifications?_method=DELETE"
        method="POST"
        onsubmit="return confirm('Clear all notifications?')"
      >
        <button class="btn btn-outline-danger btn-sm">
          <i class="fa-solid fa-trash"></i>
          Clear All
        </button>
      </form>
    <% } %>
  </div>

  <% if(notifications.length === 0){ %>
    <div class="alert alert-info rounded-4">
      No notifications yet.
    </div>
  <% } %>

  <% notifications.forEach(notification => { %>

    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body d-flex justify-content-between align-items-start">

        <a href="<%= notification.link %>" class="text-decoration-none text-dark flex-grow-1">
          <div class="d-flex gap-3">
            <div>
              <i class="fa-solid <%= notificationIcon(notification.type) %> fs-4"></i>
            </div>

            <div>
              <h6 class="mb-1">
                <%= notification.message %>
              </h6>

              <small class="text-muted">
                <i class="fa-regular fa-clock"></i>
                <%= timeAgo(notification.createdAt) %>
              </small>
            </div>
          </div>
        </a>

        <form
          action="/notifications/<%= notification._id %>?_method=DELETE"
          method="POST"
          onsubmit="return confirm('Delete this notification?')"
        >
          <button class="btn btn-sm btn-light text-danger">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </form>

      </div>
    </div>

  <% }) %>

</div>