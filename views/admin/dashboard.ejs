<% layout("layouts/boilerplate") %>

<div class="container mt-4">

  <h2 class="fw-bold mb-4">
    <i class="fa-solid fa-shield-halved text-danger"></i>
    Admin Dashboard
  </h2>

  <div class="d-flex justify-content-between align-items-center mb-4">

 

</div>

<div class="d-flex flex-wrap gap-2 mb-4">

  <a href="/admin/reports/users" class="btn btn-primary">
    <i class="fa-solid fa-users"></i> Users Report
  </a>

  <a href="/admin/reports/listings" class="btn btn-success">
    <i class="fa-solid fa-house"></i> Listings Report
  </a>

  <a href="/admin/reports/bookings" class="btn btn-danger">
    <i class="fa-solid fa-calendar-check"></i> Bookings Report
  </a>

  <a href="/admin/reports/revenue" class="btn btn-warning text-dark">
    <i class="fa-solid fa-indian-rupee-sign"></i> Revenue Report
  </a>

  <a href="/admin/reports/project" class="btn btn-dark">
  <i class="fa-solid fa-file-lines"></i>
  Project Report
</a>

</div>

  <!-- Stats Cards -->
  <div class="row mb-4">

    <div class="col-md-3 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <i class="fa-solid fa-users fs-3 text-primary mb-2"></i>
          <h4 class="fw-bold"><%= totalUsers %></h4>
          <p class="text-muted mb-0">Total Users</p>
        </div>
      </div>
    </div>

    <div class="col-md-3 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <i class="fa-solid fa-house fs-3 text-danger mb-2"></i>
          <h4 class="fw-bold"><%= totalListings %></h4>
          <p class="text-muted mb-0">Total Listings</p>
        </div>
      </div>
    </div>

    <div class="col-md-3 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <i class="fa-solid fa-calendar-check fs-3 text-success mb-2"></i>
          <h4 class="fw-bold"><%= totalBookings %></h4>
          <p class="text-muted mb-0">Total Bookings</p>
        </div>
      </div>
    </div>

    <div class="col-md-3 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <i class="fa-solid fa-indian-rupee-sign fs-3 text-warning mb-2"></i>
          <h4 class="fw-bold">₹ <%= totalRevenue.toLocaleString("en-IN") %></h4>
          <p class="text-muted mb-0">Total Revenue</p>
        </div>
      </div>
    </div>

  </div>

  <div class="row mb-4">

    <div class="col-md-4 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <h4 class="fw-bold text-success"><%= paidBookings %></h4>
          <p class="text-muted mb-0">Paid Bookings</p>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <h4 class="fw-bold text-warning"><%= pendingPayments %></h4>
          <p class="text-muted mb-0">Pending Payments</p>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-3">
      <div class="card text-center border-0 shadow-sm rounded-4">
        <div class="card-body">
          <h4 class="fw-bold text-danger"><%= cancelledBookings %></h4>
          <p class="text-muted mb-0">Cancelled Bookings</p>
        </div>
      </div>
    </div>

  </div>

  <!-- Revenue Chart -->
  <div class="card border-0 shadow-sm rounded-4 mb-5">
    <div class="card-body p-4">
      <h4 class="fw-bold mb-3">
        <i class="fa-solid fa-chart-line text-danger"></i>
        Monthly Revenue
      </h4>

      <canvas id="revenueChart" height="100"></canvas>
    </div>
  </div>

  <!-- All Users Table -->
  <h4 class="fw-bold mb-3">
    <i class="fa-solid fa-users text-primary"></i>
    All Users
  </h4>

  <div class="table-responsive mb-5">
    <table class="table table-hover align-middle bg-white rounded-4 overflow-hidden shadow-sm">
      <thead class="table-dark">
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
        </tr>
      </thead>

      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.username %></td>
            <td><%= user.email || "N/A" %></td>
            <td>
              <% if(user.role === "admin") { %>
                <span class="badge bg-danger">Admin</span>
              <% } else { %>
                <span class="badge bg-secondary">User</span>
              <% } %>
            </td>
            <td>
              <%= user.createdAt ? user.createdAt.toDateString() : "N/A" %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- All Listings Table -->
  <h4 class="fw-bold mb-3">
    <i class="fa-solid fa-house text-danger"></i>
    All Listings
  </h4>

  <div class="table-responsive mb-5">
    <table class="table table-hover align-middle bg-white rounded-4 overflow-hidden shadow-sm">
      <thead class="table-dark">
        <tr>
          <th>Title</th>
          <th>Owner</th>
          <th>Location</th>
          <th>Price</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% listings.forEach((listing) => { %>
          <tr>
            <td>
              <a href="/listings/<%= listing._id %>" class="text-decoration-none fw-semibold">
                <%= listing.title %>
              </a>
            </td>

            <td>
              <%= listing.owner ? listing.owner.username : "Unknown" %>
            </td>

            <td>
              <%= listing.location %>, <%= listing.country %>
            </td>

            <td>
              ₹ <%= listing.price.toLocaleString("en-IN") %>
            </td>

            <td>
              <form
                action="/admin/listings/<%= listing._id %>?_method=DELETE"
                method="POST"
                onsubmit="return confirm('Are you sure you want to delete this listing?')"
              >
                <button class="btn btn-sm btn-outline-danger">
                  <i class="fa-solid fa-trash"></i>
                  Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- All Bookings Table -->
  <h4 class="fw-bold mb-3">
    <i class="fa-solid fa-calendar-check text-success"></i>
    All Bookings
  </h4>

  <div class="table-responsive mb-5">
    <table class="table table-hover align-middle bg-white rounded-4 overflow-hidden shadow-sm">
      <thead class="table-dark">
        <tr>
          <th>User</th>
          <th>Listing</th>
          <th>Check In</th>
          <th>Check Out</th>
          <th>Amount</th>
          <th>Payment</th>
          <th>Status</th>
        </tr>
      </thead>

      <tbody>
        <% bookings.forEach((booking) => { %>
          <tr>
            <td><%= booking.user ? booking.user.username : "Unknown" %></td>
            <td><%= booking.listing ? booking.listing.title : "Deleted Listing" %></td>
            <td><%= booking.checkIn.toDateString() %></td>
            <td><%= booking.checkOut.toDateString() %></td>
            <td>₹ <%= booking.totalPrice.toLocaleString("en-IN") %></td>

            <td>
              <% if(booking.paymentStatus === "Paid") { %>
                <span class="badge bg-success">Paid</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } %>
            </td>

            <td>
              <% if(booking.status === "Confirmed") { %>
                <span class="badge bg-success">Confirmed</span>
              <% } else if(booking.status === "Cancelled") { %>
                <span class="badge bg-danger">Cancelled</span>
              <% } else if(booking.status === "Completed") { %>
                <span class="badge bg-primary">Completed</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const ctx = document.getElementById("revenueChart");

  const revenueChart = new Chart(ctx, {
    type: "line",
    data: {
      labels: [
        "Jan", "Feb", "Mar", "Apr", "May", "Jun",
        "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"
      ],
      datasets: [{
        label: "Revenue",
        data: <%- JSON.stringify(monthlyRevenue) %>,
        tension: 0.4,
        fill: true
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: {
          display: true
        }
      },
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });
</script>